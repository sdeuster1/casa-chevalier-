+              ? 'Your order has been received'
+              : 'Curated pieces, ready for checkout'}
+          </p>
+
+          {step === 'confirmed' && (
+            <div className="flex flex-col items-center text-center gap-6 py-8">
+              <p className="font-playfair text-dark/70 text-sm max-w-md">
